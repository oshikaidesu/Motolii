{
  "$schema": "https://www.designtokens.org/schemas/2025.10/formatSchema.json",
  "$description": "Custom theme fixture — same schema as built-in themes, distinct accent for runtime switch proof.",
  "color": {
    "surface": {
      "bg": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.12, 0.1, 0.16], "alpha": 1 } },
      "panel": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.18, 0.14, 0.22], "alpha": 1 } },
      "panel-raised": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.22, 0.17, 0.27], "alpha": 1 } },
      "inset": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.14, 0.11, 0.18], "alpha": 1 } },
      "overlay": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.2, 0.16, 0.25], "alpha": 1 } },
      "vp-surround": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.08, 0.06, 0.1], "alpha": 1 } }
    },
    "stroke": {
      "line": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.3, 0.24, 0.36], "alpha": 1 } },
      "line-strong": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.38, 0.3, 0.45], "alpha": 1 } },
      "grid-major": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.14 } },
      "grid-minor": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.05 } }
    },
    "content": {
      "primary": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.92, 0.88, 0.96], "alpha": 1 } },
      "secondary": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.72, 0.66, 0.8], "alpha": 1 } },
      "muted": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.58, 0.52, 0.66], "alpha": 1 } },
      "disabled": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.38, 0.34, 0.44], "alpha": 1 } }
    },
    "accent": {
      "selection": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.85, 0.45, 0.95], "alpha": 1 } },
      "focus": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.85, 0.45, 0.95], "alpha": 1 } },
      "on-accent": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.12, 0.04, 0.16], "alpha": 1 } }
    },
    "state": {
      "keyframe": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.95, 0.55, 0.35], "alpha": 1 } },
      "active": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.4, 0.85, 0.55], "alpha": 1 } },
      "on-active": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.06, 0.14, 0.08], "alpha": 1 } },
      "solo": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.9, 0.75, 0.3], "alpha": 1 } },
      "mute": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.55, 0.5, 0.6], "alpha": 1 } },
      "linked": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.35, 0.8, 0.85], "alpha": 1 } },
      "cached": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.6, 0.7, 0.85], "alpha": 1 } },
      "music": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.8, 0.5, 0.9], "alpha": 1 } }
    },
    "feedback": {
      "warning": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.9, 0.65, 0.25], "alpha": 1 } },
      "error": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.95, 0.45, 0.4], "alpha": 1 } }
    },
    "domain": {
      "path": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.4, 0.85, 0.55], "alpha": 1 } },
      "pixel": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.7, 0.55, 0.95], "alpha": 1 } }
    },
    "item": {
      "mesh": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.55, 0.85, 0.8], "alpha": 1 } },
      "video": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.28, 0.22, 0.42], "alpha": 1 } },
      "shape": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.35, 0.25, 0.45], "alpha": 1 } },
      "text": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.45, 0.22, 0.35], "alpha": 1 } },
      "image": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.38, 0.32, 0.28], "alpha": 1 } },
      "group": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.28, 0.38, 0.32], "alpha": 1 } },
      "particle": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.42, 0.35, 0.22], "alpha": 1 } },
      "audio": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.2, 0.25, 0.38], "alpha": 1 } }
    },
    "clip": {
      "ink": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.94, 0.9, 0.98], "alpha": 1 } },
      "border": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.24 } }
    },
    "playhead": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.98, 0.95, 1], "alpha": 1 } },
    "hover": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [1, 1, 1], "alpha": 0.06 } },
    "wave": {
      "primary": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.55, 0.45, 0.85], "alpha": 1 } },
      "secondary": { "$type": "color", "$value": { "colorSpace": "srgb", "components": [0.4, 0.32, 0.65], "alpha": 1 } }
    }
  },
  "dimension": {
    "spacing": {
      "1": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } },
      "2": { "$type": "dimension", "$value": { "value": 4, "unit": "px" } },
      "3": { "$type": "dimension", "$value": { "value": 8, "unit": "px" } },
      "4": { "$type": "dimension", "$value": { "value": 12, "unit": "px" } },
      "5": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } }
    },
    "row": {
      "s": { "$type": "dimension", "$value": { "value": 22, "unit": "px" } },
      "m": { "$type": "dimension", "$value": { "value": 26, "unit": "px" } },
      "l": { "$type": "dimension", "$value": { "value": 44, "unit": "px" } },
      "x": { "$type": "dimension", "$value": { "value": 36, "unit": "px" } }
    },
    "radius": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } },
    "icon": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } }
  }
}
